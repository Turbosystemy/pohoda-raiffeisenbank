# Logging target for Ease\Shared
EASE_LOGGER=console

# Raiffeisenbank Premium API
CERT_FILE=/path/to/raiffeisenbank.p12
CERT_PASS=changeit
XIBMCLIENTID=your-client-id
ACCOUNT_NUMBER=123456789
ACCOUNT_CURRENCY=CZK
STATEMENT_LINE=MAIN

# Optional currency conversion
CNB_CACHE=http://localhost/cnb-cache/
RATE_OFFSET=today
FIXED_RATE=
FIXED_RATE_AMOUNT=1

# Stormware Pohoda mServer connection
POHODA_URL=http://localhost:10010
POHODA_USERNAME=mServerUser
POHODA_PASSWORD=mServerPassword
POHODA_BANK_IDS=RB
POHODA_ICO=12345678
POHODA_TIMEOUT=60
POHODA_COMPRESS=false
POHODA_DEBUG=false

# Import behaviour
IMPORT_SCOPE=last_two_months
STATEMENT_SAVE_DIR=/tmp/rb-statements
JOB_ID=pohoda-rb-import
